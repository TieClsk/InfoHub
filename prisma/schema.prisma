// InfoHub Prisma Schema — 开发环境 SQLite，部署可切 PostgreSQL
//
// 架构说明：
// - ProcessedContent 冗余 sourceId + sourceName，原始数据清理后仍可独立展示
// - 跨库表之间无 Prisma 级联关系，应用层保证一致性
// - tags 字段以 JSON 字符串存储（SQLite 兼容），格式：["tag1","tag2"]

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ═══════════════════════════════════════════════════════════
// Main 表（长期保留）
// ═══════════════════════════════════════════════════════════

model DataSource {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  category    String
  type        String   // rss / rest_api / scraper
  config      String   // JSON 字符串（SQLite 不支持 Json 类型）
  schedule    String?
  isActive    Boolean  @default(true)
  lastFetchAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  @@index([category])
}

model ProcessedContent {
  id            String   @id @default(cuid())
  rawContentId  String?  @unique
  sourceId      String
  sourceName    String
  category      String
  subcategory   String?
  title         String
  summary       String
  importance    Float    @default(5)
  tags          String   @default("[]") // JSON 字符串数组
  language      String   @default("zh")
  metadata      String?                 // JSON 字符串
  processedAt   DateTime @default(now())
  publishedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([sourceId])
  @@index([category, publishedAt])
  @@index([category, importance])
  @@index([publishedAt])
}

model GithubTrending {
  id          String   @id @default(cuid())
  repoName    String
  description String?
  language    String?
  stars       Int      @default(0)
  forks       Int      @default(0)
  todayStars  Int      @default(0)
  repoUrl     String
  date        DateTime
  createdAt   DateTime @default(now())

  @@unique([repoName, date])
  @@index([date])
  @@index([language, date])
}

model WeeklySummary {
  id         String   @id @default(cuid())
  weekStart  DateTime
  weekEnd    DateTime
  content    String
  metadata   String?  // JSON 字符串
  generatedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([weekStart])
}

model FetchLog {
  id        String   @id @default(cuid())
  sourceId  String   // DataSource.name（跨库无 FK 约束）
  status    String
  total     Int      @default(0)
  newCount  Int      @default(0)
  duration  Int      @default(0)
  message   String?
  fetchedAt DateTime @default(now())

  @@index([sourceId, fetchedAt])
  @@index([fetchedAt])
}

// ═══════════════════════════════════════════════════════════
// 原始数据表（14 天自动清理）
// ═══════════════════════════════════════════════════════════

model RawContent {
  id          String   @id @default(cuid())
  sourceId    String
  externalId  String?
  externalUrl String?
  title       String
  content     String?
  sourceRank  Int?
  rawData     String?  // JSON 字符串
  language    String   @default("zh")
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([sourceId, externalUrl])
  @@unique([sourceId, externalId])
  @@index([sourceId, fetchedAt])
  @@index([createdAt])
}

// InfoHub Prisma Schema — Vercel/PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DataSource {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  category    String
  type        String
  config      String   @db.Text
  schedule    String?
  isActive    Boolean  @default(true)
  lastFetchAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model ProcessedContent {
  id            String   @id @default(cuid())
  rawContentId  String?  @unique
  sourceId      String
  sourceName    String
  category      String
  subcategory   String?
  title         String
  summary       String
  importance    Float    @default(5)
  tags          String   @default("[]")
  language      String   @default("zh")
  metadata      String?  @db.Text
  processedAt   DateTime @default(now())
  publishedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([sourceId])
  @@index([category, publishedAt])
  @@index([category, importance])
  @@index([publishedAt])
}

model GithubTrending {
  id          String   @id @default(cuid())
  repoName    String
  description String?
  language    String?
  stars       Int      @default(0)
  forks       Int      @default(0)
  todayStars  Int      @default(0)
  repoUrl     String
  date        DateTime @db.Date
  createdAt   DateTime @default(now())

  @@unique([repoName, date])
  @@index([date])
  @@index([language, date])
}

model WeeklySummary {
  id         String   @id @default(cuid())
  weekStart  DateTime @db.Date
  weekEnd    DateTime @db.Date
  content    String   @db.Text
  metadata   String?  @db.Text
  generatedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([weekStart])
}

model FetchLog {
  id        String   @id @default(cuid())
  sourceId  String
  status    String
  total     Int      @default(0)
  newCount  Int      @default(0)
  duration  Int      @default(0)
  message   String?  @db.Text
  fetchedAt DateTime @default(now())

  @@index([sourceId, fetchedAt])
  @@index([fetchedAt])
}

model RawContent {
  id          String   @id @default(cuid())
  sourceId    String
  externalId  String?
  externalUrl String?
  title       String
  content     String?  @db.Text
  sourceRank  Int?
  rawData     String?  @db.Text
  language    String   @default("zh")
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([sourceId, externalUrl])
  @@unique([sourceId, externalId])
  @@index([sourceId, fetchedAt])
  @@index([createdAt])
}

model Guestbook {
  id        String   @id @default(cuid())
  content   String   @db.Text
  author    String   @default("匿名")
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}


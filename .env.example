# Main DB — 精选展示数据（长期保留）
DATABASE_URL="postgresql://user:password@localhost:5432/infohub_main"

# Raw DB — 原始采集数据（14 天自动清理）
# 开发阶段可与主库指向同一 PostgreSQL，部署时拆分为独立实例
RAW_DATABASE_URL="postgresql://user:password@localhost:5432/infohub_raw"

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据源 API Keys
NEWS_API_KEY=
TIANXING_API_KEY=

# 定时任务鉴权
CRON_SECRET=          # 不少于 32 字符

# 原始数据保留天数（默认 14）
RAW_RETENTION_DAYS=14

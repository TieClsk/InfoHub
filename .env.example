# 本地开发：SQLite（无需安装数据库）
DATABASE_URL="file:./dev.db"

# Vercel 部署：替换为 Neon/Vercel Postgres 连接字符串
# DATABASE_URL="postgresql://user:password@host:5432/infohub"

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据源 API Keys
NEWS_API_KEY=
TIANXING_API_KEY=

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=infohub2025

# 定时任务鉴权（不少于 32 字符）
CRON_SECRET=

# 原始数据保留天数（默认 2 天）
RAW_RETENTION_DAYS=2

# 定时任务调度（自托管用，node-cron 表达式，注释掉则不启用）
# 每日采集+AI处理：每天凌晨 0:00
CRON_SCHEDULE=0 0 * * *
# 周报生成：每周一凌晨 1:00
CRON_WEEKLY_SCHEDULE=0 1 * * 1
